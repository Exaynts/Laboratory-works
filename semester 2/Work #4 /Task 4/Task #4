#include <iostream>
#include <vector>
using namespace std;

int main() {
    setlocale(LC_ALL, "ru");
    // Создание массива
    const int n = 5;
    vector <string> peaks {"Лхоцзе", "Джомолунгма", "Дхаулагири", "Камет", "Ракапоши"};
    vector <string> long_peaks;
    // Список вершин, с названиями длиннее 7 букв
    for (int i = 0; i < n; i++) {
        if (size(peaks[i]) > 7) {
            long_peaks.push_back(peaks[i]);
    }
    // Сортировка списка
    sort(long_peaks.begin(), long_peaks.end());
    // Вывод нового списка
    for (int i = 0; i < n; i++) {
        cout << peaks[i] << endl;
    }
    return 0;
}

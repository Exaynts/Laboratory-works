#include <iostream>
using namespace std;

int main()
{
    setlocale(LC_ALL, "ru");
    //system("chcp 1251");
      // Создание массива
    const int n = 10;
    string cities[n]{ "Париж", "Лондон", "Лиссабон", "Киев",
        "Москва", "Прага", "Рим", "Копенгаген", "Бухарест", "Ставрополь"};
    int i = 0;
    int j = 0;
    int A[2]; // Индексы нужных городов
    while (j < 2 and i < n) {
        int p = cities[i].size() - 1;
        cout << "p = " << cities[i][p] << endl;
        if (cities[i][p] == 'а') {
            cout << "1" << endl;
            A[j] = i;
            j += 1;
        }
        i += 1;
        cout << "0" << endl;
    }
    // Замена местами двух городов, оканчивающихся на "а"
    swap(cities[A[0]], cities[A[1]]);
    // Вывод нового списка
    for (int i = 0; i < n; i++) {
        cout << cities[i] << endl;
    }
}

#include <iostream>
#include <fstream>
using namespace std;

int main() {
    setlocale(LC_ALL, "russian");
    ifstream inputFile("a.txt");

    double number;
    int zeros = 0; // Счетчик нулевых элементов
    double zeroone = 1; // Произведение элементов, меньших 1 и больших 0

    while (inputFile >> number) {
        if (number == 0) {
            zeros += 1;
        } 
        else if (number > 0 and number < 1) {
            zeroone *= number;
        }
    }
    inputFile.close();

    cout << "Количество нулевых элементов: " << zeros << endl;
    cout << "Произведение элементов, меньших 1 и больших 0: " << zeroone << endl;
    return 0;
}
